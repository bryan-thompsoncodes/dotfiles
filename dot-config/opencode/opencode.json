{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "name": "OpenAI",
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Open WebUI (ai.thompson.codes)",
      "options": {
        "baseURL": "https://ai.thompson.codes/api/v1",
        "apiKey": "{file:~/.secrets/opencode-api-key}"
      },
      "models": {
        "gemma4:26b-a4b-it-q8_0": {
          "name": "Gemma 4 26B",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "gemma4:e4b-it-q8_0": {
          "name": "Gemma 4 Fast 8B",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "qwen3.5:27b": {
          "name": "Qwen 3.5 27B",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "qwen3.5:9b": {
          "name": "Qwen 3.5 9B",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },
  "instructions": [
    "README.md",
    "AGENTS.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log*": "allow",
