{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "disabled_agents": [
    "README"
  ],
  "lsp": {
    "gdscript": {
      "command": [
        "/Users/bryan/.config/opencode/scripts/gdscript-lsp-bridge.sh"
      ],
      "extensions": [
        ".gd"
      ]
    },
    "marksman": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "agents": {
    "sisyphus": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "variant": "max"
    },
    "sisyphus-junior": {
      "model": "openrouter/openai/gpt-5.4-mini"
    },
    "hephaestus": {
      "model": "openrouter/openai/gpt-5.4"
    },
    "prometheus": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "variant": "max"
    },
    "oracle": {
      "model": "openrouter/openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openrouter/openai/gpt-5.4",
      "variant": "xhigh"
    },
    "metis": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "variant": "max"
    },
    "atlas": {
      "model": "openrouter/anthropic/claude-sonnet-4.6"
    },
    "explore": {
      "model": "openrouter/anthropic/claude-haiku-4.5"
    },
    "librarian": {
      "model": "openrouter/anthropic/claude-haiku-4.5"
    },
    "multimodal-looker": {
      "model": "openrouter/openai/gpt-5.4"
    },
    "muse": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "temperature": 0.6,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 64000
      }
    },
    "archivist": {
      "model": "openrouter/anthropic/claude-haiku-4.5",
      "temperature": 0.1
    },
    "scribe": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "temperature": 0.2
    },
    "pyre": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "temperature": 0.1
    },
    "sage": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "temperature": 0.2
    },
    "demiurge": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "temperature": 0.2,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    "forge": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "temperature": 0.2
    },
    "kindle": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "temperature": 0.4
    },
    "aria": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "temperature": 0.2
    },
    "calliope": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "temperature": 0.35
    },
    "commit-msg": {
      "model": "openrouter/anthropic/claude-haiku-4.5",
      "temperature": 0.1
    },
    "gamedev": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "temperature": 0.3
    },
    "prism": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "temperature": 0.55,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 48000
      }
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "variant": "max"
    },
    "ultrabrain": {
      "model": "openrouter/openai/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openrouter/openai/gpt-5.4"
    },
    "quick": {
      "model": "openrouter/openai/gpt-5.4-mini"
    },
    "unspecified-low": {
      "model": "openrouter/anthropic/claude-sonnet-4.6"
    },
    "unspecified-high": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "variant": "max"
    },
    "writing": {
      "model": "openrouter/anthropic/claude-sonnet-4.6"
    },
    "artistry": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "variant": "max"
    },
    "ideation": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "temperature": 0.7,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 64000
      },
      "prompt_append": "Focus on creative exploration, brainstorming, and structured thinking. Use extended thinking to explore ideas deeply. Capture insights using athena-notes patterns."
    },
    "codex": {
      "model": "openrouter/openai/gpt-5.4",
      "variant": "high",
      "description": "Code-focused tasks using GPT Codex - optimized for code generation, refactoring, and implementation"
    }
  },
  "_migrations": [
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
    "model-version:anthropic/claude-opus-4-6->openrouter/anthropic/claude-opus-4.7",
    "model-version:anthropic/claude-sonnet-4-6->openrouter/anthropic/claude-sonnet-4.6",
    "model-version:anthropic/claude-haiku-4-5->openrouter/anthropic/claude-haiku-4.5",
    "model-version:openai/gpt-5.4->openrouter/openai/gpt-5.4",
    "model-version:openai/gpt-5.4-mini->openrouter/openai/gpt-5.4-mini"
  ]
}
